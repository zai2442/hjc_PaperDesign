{
  "info": {
    "_postman_id": "c4d0a62a-9d9f-4aaf-9fdd-2e0d2f12c8c4",
    "name": "CAMS - Registration Module",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "studentToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "activityId", "value": "1" },
    { "key": "registrationId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Login (student1)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"student1\",\n  \"password\": \"123456\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('studentToken', json.data);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Login (admin)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('adminToken', json.data);"
            ]
          }
        }
      ]
    },
    {
      "name": "Student - Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{studentToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/v1/registrations", "host": ["{{baseUrl}}"], "path": ["api", "v1", "registrations"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"activityId\": {{activityId}},\n  \"extraData\": \"{}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('status code 200', () => pm.response.code === 200);",
              "pm.collectionVariables.set('registrationId', String(json.data));"
            ]
          }
        }
      ]
    },
    {
      "name": "Student - My Registrations",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/registrations/my?page=1&size=10", "host": ["{{baseUrl}}"], "path": ["api", "v1", "registrations", "my"], "query": [{ "key": "page", "value": "1" }, { "key": "size", "value": "10" }] }
      }
    },
    {
      "name": "Admin - List Registrations (by activity)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/registrations?activityId={{activityId}}&page=1&size=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "registrations"],
          "query": [
            { "key": "activityId", "value": "{{activityId}}" },
            { "key": "page", "value": "1" },
            { "key": "size", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "Admin - Audit Registration (approve)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/v1/admin/registrations/{{registrationId}}/audit", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "registrations", "{{registrationId}}", "audit"] },
        "body": { "mode": "raw", "raw": "{\n  \"status\": \"APPROVED\",\n  \"reason\": \"ok\"\n}" }
      }
    },
    {
      "name": "Admin - Stats",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/registrations/stats?activityId={{activityId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "registrations", "stats"],
          "query": [{ "key": "activityId", "value": "{{activityId}}" }]
        }
      }
    }
  ]
}

